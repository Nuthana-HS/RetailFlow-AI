# =============================================================================
# RetailFlow AI — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# BACKEND — DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
# Development (Docker):
DATABASE_URL=postgresql+asyncpg://retailflow:retailflow_dev_password@postgres:5432/retailflow_db

# Production (Neon PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/retailflow?sslmode=require

# Test database (used by pytest):
TEST_DATABASE_URL=postgresql+asyncpg://retailflow:retailflow_dev_password@postgres:5432/retailflow_test

# Database pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# BACKEND — REDIS
# -----------------------------------------------------------------------------
# Development (Docker):
REDIS_URL=redis://redis:6379/0

# Production (Upstash/Redis Cloud):
# REDIS_URL=rediss://user:password@host:6380/0

# Redis settings
REDIS_MAX_CONNECTIONS=20

# -----------------------------------------------------------------------------
# BACKEND — JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_secure_random_string_at_least_32_chars_long

JWT_ALGORITHM=HS256

# Access token expiry (seconds)
ACCESS_TOKEN_EXPIRE_SECONDS=900    # 15 minutes

# Refresh token expiry (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# BACKEND — CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Production:
# CORS_ORIGINS=https://retailflow.vercel.app,https://www.retailflow.ai

# -----------------------------------------------------------------------------
# BACKEND — RATE LIMITING
# -----------------------------------------------------------------------------
# Requests per minute for unauthenticated endpoints
RATE_LIMIT_UNAUTHENTICATED=100

# Requests per minute for authenticated endpoints
RATE_LIMIT_AUTHENTICATED=1000

# -----------------------------------------------------------------------------
# BACKEND — AI SERVICE INTEGRATION
# -----------------------------------------------------------------------------
# URL of the AI service (use Docker service name in Docker Compose)
AI_SERVICE_URL=http://ai-service:8001

# Secret key for service-to-service authentication
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
AI_SERVICE_API_KEY=CHANGE_ME_internal_service_secret_key

# Timeout for AI service calls (seconds)
AI_SERVICE_TIMEOUT=30

# -----------------------------------------------------------------------------
# BACKEND — EMAIL (SendGrid / SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_your_sendgrid_api_key
SMTP_FROM_EMAIL=noreply@retailflow.ai
SMTP_FROM_NAME=RetailFlow AI

# Set to false in development to disable email sending
SEND_EMAILS=false

# -----------------------------------------------------------------------------
# BACKEND — APP SETTINGS
# -----------------------------------------------------------------------------
# Queue alert cooldown (minutes) — minimum time between repeated alerts
DEFAULT_ALERT_COOLDOWN_MINUTES=30

# Default queue alert threshold (customers)
DEFAULT_QUEUE_ALERT_THRESHOLD=8

# Default average service time per customer (seconds)
DEFAULT_AVG_SERVICE_TIME_SECONDS=180

# CV update interval (seconds) — how often AI service pushes queue counts
CV_UPDATE_INTERVAL_SECONDS=5

# ML prediction cache TTL (seconds)
ML_PREDICTION_CACHE_TTL_SECONDS=30

# -----------------------------------------------------------------------------
# AI SERVICE — COMPUTER VISION
# -----------------------------------------------------------------------------
# YOLOv8 model size: n (nano), s (small), m (medium), l (large), x (extra-large)
# Recommendation: 'n' for CPU, 'm' for GPU
YOLO_MODEL_SIZE=n

# Confidence threshold for person detection (0.0–1.0)
YOLO_CONFIDENCE_THRESHOLD=0.5

# Minimum detection confidence to include in queue count
YOLO_MIN_CONFIDENCE=0.4

# Video frame processing interval (milliseconds)
CV_FRAME_INTERVAL_MS=500

# -----------------------------------------------------------------------------
# AI SERVICE — ML MODEL
# -----------------------------------------------------------------------------
# Path to the serialized XGBoost model file
ML_MODEL_PATH=models/wait_time_predictor_v1.pkl

# Minimum confidence score to use ML prediction (fallback to rule-based below)
ML_MIN_CONFIDENCE_THRESHOLD=0.7

# Retrain model if data is older than N days
ML_RETRAIN_INTERVAL_DAYS=7

# -----------------------------------------------------------------------------
# AI SERVICE — CORE API CONNECTION
# -----------------------------------------------------------------------------
CORE_API_URL=http://backend:8000
CORE_API_SERVICE_KEY=CHANGE_ME_internal_service_secret_key  # must match AI_SERVICE_API_KEY above

# -----------------------------------------------------------------------------
# FRONTEND — Next.js (Public variables — exposed to browser)
# -----------------------------------------------------------------------------
# Base URL of the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket base URL (ws:// for dev, wss:// for production)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Application metadata
NEXT_PUBLIC_APP_NAME=RetailFlow AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# DOCKER / POSTGRES CONTAINER (used by docker-compose.yml)
# -----------------------------------------------------------------------------
POSTGRES_USER=retailflow
POSTGRES_PASSWORD=retailflow_dev_password
POSTGRES_DB=retailflow_db

# -----------------------------------------------------------------------------
# GITHUB ACTIONS / CI CD (set as repository secrets, not here)
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=           → GitHub Secret
# VERCEL_ORG_ID=          → GitHub Secret
# VERCEL_PROJECT_ID=      → GitHub Secret
# RENDER_BACKEND_DEPLOY_HOOK=   → GitHub Secret
# RENDER_AI_DEPLOY_HOOK=        → GitHub Secret
